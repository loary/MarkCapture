{
    "manifest_version": 3,
    "name": "网页转 Markdown",
    "short_name": "html2md",
    "version": "1.0.0",
    "description": "一键将当前网页内容转换为 Markdown 格式，支持预览、下载保存和语音朗读",
    "author": "html2md",
    "homepage_url": "https://github.com/helloworld-Co/html2md",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "activeTab",
        "downloads",
        "storage",
        "scripting"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "网页转 Markdown",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["lib/html2md.js", "content/content.js"],
            "run_at": "document_idle"
        }
    ],
    "commands": {
        "convert-to-markdown": {
            "suggested_key": {
                "default": "Alt+Shift+M",
                "mac": "Command+Shift+M"
            },
            "description": "转换当前页面为 Markdown"
        }
    }
}